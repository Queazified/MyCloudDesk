# Core app settings
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myclouddesk?schema=public

# Local development login mode
AUTH_ENABLE_MOCK=true
ADMIN_EMAILS=admin@queazified.co.uk

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Authentik OIDC
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_ISSUER=

# Generic OIDC
GENERIC_OIDC_NAME=Generic OIDC
GENERIC_OIDC_CLIENT_ID=
GENERIC_OIDC_CLIENT_SECRET=
GENERIC_OIDC_ISSUER=

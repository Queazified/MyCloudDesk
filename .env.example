# Core app settings
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myclouddesk?schema=public

# Development host allowlist for Next.js dev assets.
# Add your LAN IP host when opening the app from another device.
# Example: ALLOWED_DEV_ORIGINS=localhost,127.0.0.1,192.168.1.18
ALLOWED_DEV_ORIGINS=localhost,127.0.0.1

# Local development login mode
AUTH_ENABLE_MOCK=true
ADMIN_EMAILS=admin@queazified.co.uk

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Authentik OIDC
# Use the provider issuer URL without trailing slash, for example:
# AUTHENTIK_ISSUER=https://auth.queazified.co.uk/application/o/my-cloud-desk
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_ISSUER=

# OAuth discovery and provider request timeout in milliseconds.
# Increase this if your IdP is slow or behind reverse proxy latency.
OAUTH_HTTP_TIMEOUT_MS=10000

# Generic OIDC
GENERIC_OIDC_NAME=Generic OIDC
GENERIC_OIDC_CLIENT_ID=
GENERIC_OIDC_CLIENT_SECRET=
GENERIC_OIDC_ISSUER=
